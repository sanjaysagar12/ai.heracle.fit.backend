// Prisma generator & datasource (globals)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


// Core user table storing all user accounts.
model User {
  id        String    @id @default(uuid()) @map("id") @db.Uuid
  username  String    @unique @map("username")
  name      String    @map("name")
  bio       String?   @map("bio")
  avatarUrl String?   @map("avatar_url")
  email     String    @unique @map("email")
  role      String    @default("user") @map("role")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  // relations
  profile UserProfile?
  meals   Meal[]

  @@map("users")
}


// User fitness profile — stores onboarding and health data for AI personalisation.
model UserProfile {
    id     String @id @default(uuid()) @map("id") @db.Uuid
    userId String @unique @map("user_id") @db.Uuid

    // ── Demographics ─────────────────────────────────────────────────────────
    age    Int?    @map("age")
    gender String? @map("gender") // e.g. "male" | "female" | "other"

    // ── Body Metrics ──────────────────────────────────────────────────────────
    heightCm  Float?  @map("height_cm") // always stored in cm
    heightFt  Float?  @map("height_ft") // optional user-facing display in ft
    weightKg  Float?  @map("weight_kg") // always stored in kg
    weightLbs Float?  @map("weight_lbs") // optional user-facing display in lbs
    bodyType  String? @map("body_type") // e.g. "ectomorph" | "mesomorph" | "endomorph"

    // ── Fitness Goals & Level ─────────────────────────────────────────────────
    goal                String? @map("goal") // e.g. "weight_loss" | "muscle_gain" | "endurance"
    fitnessLevel        String? @map("fitness_level") // e.g. "beginner" | "intermediate" | "advanced"
    bmi                 Float?  @map("bmi")
    maintenanceCalories Int?    @map("maintenance_calories")

    // ── Workout Preferences ────────────────────────────────────────────────────
    workoutFrequencyPerWeek Int?     @map("workout_frequency_per_week") // e.g. 3
    preferredWorkoutType    String?  @map("preferred_workout_type") // e.g. "strength" | "cardio" | "yoga"
    availableDays           String[] @map("available_days") // e.g. ["monday", "wednesday", "friday"]
    preferredWorkoutTime    String?  @map("preferred_workout_time") // e.g. "morning" | "evening"
    sessionDurationMins     Int?     @map("session_duration_mins") // e.g. 45

    // ── Health & Injuries ─────────────────────────────────────────────────────
    injuries String? @map("injuries") // free-text, e.g. "left knee pain, lower back strain"

    // ── Nutrition ─────────────────────────────────────────────────────────────
    dietaryPreference String? @map("dietary_preference") // e.g. "vegan" | "keto" | "none"
    dailyWaterLitres  Float?  @map("daily_water_litres") // e.g. 2.5
    mealsPerDay       Int?    @map("meals_per_day") // e.g. 3

    // ── Timestamps ────────────────────────────────────────────────────────────
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime? @map("updated_at")

    // ── Relation ──────────────────────────────────────────────────────────────
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("user_profiles")
}


// Diet — Meal log table
model Meal {
    id        String   @id @default(uuid()) @db.Uuid
    userId    String   @map("user_id") @db.Uuid
    mealType  String   @map("meal_type") // "breakfast" | "lunch" | "dinner" | "snack"
    date      String   @map("date") //  "YYYY-MM-DD"
    time      String   @map("time") //  "HH:MM"
    data      Json     @map("data") // FoodItem[] — see LogMealResponseDto
    createdAt DateTime @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("meals")
}
